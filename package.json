{
  "name": "@cachly-dev/mcp-server",
  "version": "0.9.7",
  "mcpName": "io.github.cachly-dev/cachly-mcp",
  "description": "Your AI forgets everything between sessions. cachly fixes that permanently. A causal brain that learns WHY things break — built from every bug fix, git commit, and CI run, without any explicit calls. Arrives pre-briefed each session. Predicts failures before they happen. Never re-researches the same problem. 63 MCP tools · Claude Code · Cursor · GitHub Copilot · Windsurf · Free tier · EU servers.",
  "type": "module",
  "bin": {
    "cachly-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "postinstall": "node scripts/postinstall.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cachly-dev/cachly-mcp.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "cursor",
    "copilot",
    "github-copilot",
    "windsurf",
    "continue",
    "ai-memory",
    "ai-brain",
    "persistent-memory",
    "brain",
    "sessions",
    "lessons-learned",
    "semantic-cache",
    "team-knowledge",
    "ambient-git",
    "memory-crystals",
    "causal-knowledge-graph",
    "continuous-learning",
    "predictive-ai",
    "cachly",
    "redis",
    "valkey",
    "cache",
    "ai",
    "llm",
    "knowledge-base",
    "developer-productivity",
    "ckg",
    "mcp-server"
  ],
  "homepage": "https://cachly.dev/docs/mcp",

{
  "name": "@cachly-dev/mcp-server",
  "version": "0.5.39",
  "mcpName": "io.github.cachly-dev/mcp-server",
  "description": "AI memory brain for Claude Code, Cursor, Copilot & Windsurf — persistent sessions, lessons learned, semantic search, team brain. 51 MCP tools.",
  "type": "module",
  "bin": {
    "cachly-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "postinstall": "node scripts/postinstall.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cachly-dev/cachly-mcp"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "cursor",
    "copilot",
    "github-copilot",
    "windsurf",
    "continue",
    "ai-memory",
    "brain",
    "sessions",
    "lessons-learned",
    "semantic-cache",
    "team-knowledge",
    "ambient-git",
    "memory-crystals",
    "cachly",
    "redis",
    "valkey",
    "cache",
    "ai",
    "llm"
  ],
  "homepage": "https://cachly.dev/docs/mcp",
  "bugs": {
    "url": "https://github.com/cachly-dev/cachly-mcp/issues"
  }
}
